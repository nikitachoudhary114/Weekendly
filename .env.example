# Local dev: copy to .env.local
# Deploy: set in Vercel/Netlify/Render/etc. as VITE_GOOGLE_MAPS_API_KEY, then rebuild
#
# Name must be EXACTLY: VITE_GOOGLE_MAPS_API_KEY  (VITE_ prefix is required)
# Get a key: https://console.cloud.google.com/google/maps-apis
# Enable: Maps JavaScript API, Places API (New)
VITE_GOOGLE_MAPS_API_KEY=your_key_here
